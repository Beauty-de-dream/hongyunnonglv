/* pages/settings/settings.wxss */

.page-settings {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* ========== 设置卡片 ========== */
.settings-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* ========== 老人模式横幅 ========== */
.card-header-banner {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.banner-text {
  flex: 1;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  display: block;
}

/* ========== 切换开关行 ========== */
.elder-toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.toggle-info {
  flex: 1;
}

.toggle-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.toggle-hint {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.elder-switch {
  transform: scale(1.2);
}

/* ========== 功能说明列表 ========== */
.elder-features {
  padding: 24rpx 32rpx;
}

.feature-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.feature-check {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.feature-text {
  font-size: 28rpx;
  color: #555;
}

/* ========== 普通设置列表 ========== */
.settings-group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 32rpx 12rpx;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background: #f9f9f9;
}

.settings-item-left {
  display: flex;
  align-items: center;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.settings-label {
  font-size: 30rpx;
  color: #333;
}

.settings-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* ========== 老人模式下的菜单 ========== */
.elder-menu-item {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.elder-menu-item:last-child {
  border-bottom: none;
}

.elder-menu-item:active {
  background: #f5f5f5;
}

.elder-menu-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.elder-menu-text {
  font-size: 38rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.elder-menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* ========== 朗读悬浮按钮 ========== */
.read-aloud-fab {
  position: fixed;
  right: 32rpx;
  bottom: 350rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #FF9800 0%, #FFB74D 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255,152,0,0.4);
  z-index: 999;
  transition: transform 0.2s ease;
}

.read-aloud-fab:active {
  transform: scale(0.92);
}

.read-aloud-icon {
  font-size: 40rpx;
  line-height: 1;
}

.read-aloud-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  margin-top: 4rpx;
}

/* ========== 版本信息 ========== */
.version-info {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.version-text {
  font-size: 26rpx;
  color: #bbb;
  display: block;
  margin-bottom: 8rpx;
}

.version-copyright {
  font-size: 22rpx;
  color: #ddd;
  display: block;
}

/* ========== 老人模式样式覆盖 ========== */
.page-settings.elder-mode {
  background: #fff;
}

.page-settings.elder-mode .banner-title {
  font-size: 44rpx;
}

.page-settings.elder-mode .banner-desc {
  font-size: 30rpx;
}

.page-settings.elder-mode .toggle-label {
  font-size: 40rpx;
}

.page-settings.elder-mode .toggle-hint {
  font-size: 30rpx;
}

.page-settings.elder-mode .elder-switch {
  transform: scale(1.5);
}

.page-settings.elder-mode .feature-text {
  font-size: 36rpx;
}

.page-settings.elder-mode .feature-check {
  font-size: 40rpx;
}

.page-settings.elder-mode .version-text {
  font-size: 32rpx;
}

.page-settings.elder-mode .version-copyright {
  font-size: 28rpx;
}
