.page-courses {
  min-height: 100vh;
  background: #f4f7fb;
  padding-bottom: 32rpx;
}

.hero-banner {
  position: relative;
  overflow: hidden;
  height: 340rpx;
  padding: 48rpx 34rpx;
  background: linear-gradient(135deg, #163a70 0%, #1565C0 46%, #00897B 100%);
  display: flex;
  align-items: flex-end;
}

.hero-shape {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-shape-one {
  width: 260rpx;
  height: 260rpx;
  top: -90rpx;
  right: -30rpx;
}

.hero-shape-two {
  width: 160rpx;
  height: 160rpx;
  bottom: 20rpx;
  right: 140rpx;
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-badge {
  width: fit-content;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.7;
}

.stats-panel {
  margin: -22rpx 24rpx 18rpx;
  padding: 20rpx 10rpx;
  background: #fff;
  border-radius: 22rpx;
  display: flex;
  box-shadow: 0 12rpx 22rpx rgba(21, 101, 192, 0.08);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 30rpx;
  font-weight: bold;
  color: #1565C0;
}

.stat-label {
  font-size: 22rpx;
  color: #74839a;
}

.category-bar {
  white-space: nowrap;
  padding: 0 24rpx 10rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #d9e5f2;
  color: #5a6d87;
  font-size: 24rpx;
}

.category-chip-active {
  background: linear-gradient(135deg, #1565C0, #00897B);
  border-color: transparent;
  color: #fff;
}

.tips-card,
.footer-card {
  margin: 0 24rpx 18rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 18rpx rgba(21, 101, 192, 0.06);
}

.tips-title,
.footer-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #123a68;
  margin-bottom: 12rpx;
}

.tips-desc,
.footer-desc {
  display: block;
  font-size: 25rpx;
  color: #647992;
  line-height: 1.8;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 0 24rpx;
}

.course-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 22rpx rgba(21, 101, 192, 0.08);
}

.course-image {
  width: 100%;
  height: 250rpx;
}

.course-body {
  padding: 24rpx;
}

.course-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.course-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #183d6b;
  margin-bottom: 8rpx;
}

.course-instructor {
  display: block;
  font-size: 23rpx;
  color: #6f8196;
}

.course-category {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e4f2ef;
  color: #00897B;
  font-size: 22rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.info-text {
  font-size: 23rpx;
  color: #56708d;
  background: #f2f7fb;
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
}

.course-location {
  display: block;
  font-size: 24rpx;
  color: #566f8d;
  margin-bottom: 12rpx;
}

.course-desc {
  display: block;
  font-size: 25rpx;
  color: #596f88;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef6ff;
  color: #1565C0;
  font-size: 22rpx;
}

.course-actions {
  display: flex;
  gap: 16rpx;
}

.ghost-btn,
.solid-btn,
.footer-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.ghost-btn {
  color: #1565C0;
  background: #edf5ff;
}

.solid-btn,
.footer-btn {
  color: #fff;
  background: linear-gradient(135deg, #1565C0, #00897B);
}

.empty-state {
  padding: 80rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #7b8fa8;
}
