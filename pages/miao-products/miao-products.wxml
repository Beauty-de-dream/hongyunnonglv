<view class="page-products {{elderMode ? 'elder-mode' : ''}}">
  <view class="hero-banner">
    <view class="hero-overlay"></view>
    <view class="hero-content">
      <text class="hero-badge">苗乡风情 · 子页面</text>
      <text class="hero-title">苗族非遗文创销售</text>
      <text class="hero-subtitle">为苗绣、银饰、蜡染等非遗文创产品提供线上展销服务</text>
    </view>
  </view>

  <view class="promise-bar">
    <view class="promise-item">
      <text class="promise-icon">🪡</text>
      <text class="promise-text">匠人手作</text>
    </view>
    <view class="promise-item">
      <text class="promise-icon">✨</text>
      <text class="promise-text">非遗精选</text>
    </view>
    <view class="promise-item">
      <text class="promise-icon">📦</text>
      <text class="promise-text">线上展销</text>
    </view>
  </view>

  <scroll-view scroll-x class="category-bar">
    <view
      class="category-item {{selectedCategory === item ? 'category-item-active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      data-category="{{item}}"
      bindtap="filterCategory"
    >
      {{item}}
    </view>
  </scroll-view>

  <view class="intro-card">
    <text class="intro-title">让苗族非遗走向更广阔的市场</text>
    <text class="intro-desc">这里聚合苗绣、银饰、蜡染等代表性文创产品，既展示工艺之美，也帮助本地传承人拓宽销售渠道。</text>
  </view>

  <view class="product-list">
    <view class="product-card" wx:for="{{filteredProducts}}" wx:key="id" bindtap="showProductDetail" data-index="{{index}}">
      <image class="product-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="product-body">
        <view class="product-head">
          <text class="product-name">{{item.name}}</text>
          <view class="product-category">{{item.category}}</view>
        </view>
        <text class="product-desc">{{item.description}}</text>
        <view class="product-meta">
          <text class="meta-text">匠人：{{item.artisan}}</text>
          <text class="meta-text">库存：{{item.stock}}</text>
        </view>
        <view class="tag-row">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
        <view class="product-footer">
          <view>
            <text class="product-price">¥{{item.price}}</text>
            <text class="product-unit">/{{item.unit}}</text>
            <text class="product-sales"> 已售 {{item.sales}}</text>
          </view>
          <view class="buy-btn" catchtap="buyNow" data-index="{{index}}">立即购买</view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{filteredProducts.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">当前分类暂无商品</text>
  </view>

  <view class="bottom-card">
    <text class="bottom-title">想亲手做一件苗族非遗作品？</text>
    <text class="bottom-desc">除了线上选购，你还可以直接预约苗绣、银饰、蜡染体验课程。</text>
    <view class="bottom-btn" bindtap="goToCourses">去看体验课程 →</view>
  </view>
</view>
