/* pages/redculture/redculture.wxss */

.page-red {
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

/* ===== Hero Banner ===== */
.hero-banner {
  height: 380rpx;
  background: linear-gradient(135deg, #B71C1C 0%, #C62828 45%, #E53935 100%);
  position: relative;
  overflow: hidden;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.hero-content {
  display: flex;
  flex-direction: column;
  z-index: 1;
}

.hero-badge {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.18);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  display: inline-block;
  width: fit-content;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

/* ===== Quick Nav ===== */
.quick-nav {
  display: flex;
  background: #fff;
  padding: 28rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.nav-item:active { opacity: 0.7; }

.nav-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.nav-icon-red    { background: #FFEBEE; }
.nav-icon-orange { background: #FFF3E0; }
.nav-icon-gold   { background: #FFFDE7; }
.nav-icon-warm   { background: #FBE9E7; }

.nav-text {
  font-size: 24rpx;
  color: #555;
}

/* ===== Sections ===== */
.section {
  padding: 40rpx 24rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.section-gray { background: #f5f5f5; }

.section-header { margin-bottom: 30rpx; }

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.title-bar {
  width: 6rpx;
  height: 40rpx;
  border-radius: 3rpx;
}

.title-bar-red { background: #C62828; }

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #222;
}

.section-subtitle {
  font-size: 26rpx;
  color: #999;
  padding-left: 18rpx;
}

/* ===== Article Cards ===== */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.article-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  display: flex;
  flex-direction: row;
}

.article-card:active { transform: scale(0.98); }

.article-image {
  width: 220rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.article-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.article-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.article-category {
  font-size: 22rpx;
  color: #C62828;
  background: #FFEBEE;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

.article-date {
  font-size: 22rpx;
  color: #bbb;
}

.article-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}

.article-summary {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  display: block;
  overflow: hidden;
}

.article-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  padding-top: 12rpx;
}

.article-reads { font-size: 22rpx; color: #bbb; }
.article-more  { font-size: 24rpx; color: #C62828; font-weight: bold; }

/* ===== Site Cards ===== */
.site-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.site-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
}

.site-card:active { transform: scale(0.98); }

.site-image {
  width: 100%;
  height: 280rpx;
}

.site-loc-badge {
  background: rgba(198, 40, 40, 0.85);
  color: #fff;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  display: inline-block;
  margin: -28rpx 0 0 16rpx;
  border-radius: 20rpx;
  position: relative;
  z-index: 2;
}

.site-info { padding: 16rpx 24rpx 24rpx; }

.site-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
  display: block;
  margin-bottom: 10rpx;
  margin-top: 10rpx;
}

.site-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: block;
  margin-bottom: 14rpx;
}

.site-meta {
  display: flex;
  gap: 24rpx;
  align-items: center;
  margin-bottom: 16rpx;
}

.site-time { font-size: 24rpx; color: #888; }

.site-price-badge {
  font-size: 24rpx;
  color: #2E7D32;
  background: #E8F5E9;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
}

.site-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.site-checked { font-size: 24rpx; color: #888; }

.checkin-btn {
  background: linear-gradient(90deg, #C62828, #E53935);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.checkin-btn:active { opacity: 0.85; }

/* ===== Guide Cards ===== */
.guide-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.guide-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.guide-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.guide-avail-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  padding: 3rpx 10rpx;
  border-radius: 10rpx;
  white-space: nowrap;
  color: #fff;
}

.badge-avail { background: #4CAF50; }
.badge-busy  { background: #999; }

.guide-info { flex: 1; min-width: 0; }

.guide-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.guide-name { font-size: 30rpx; font-weight: bold; color: #222; }

.guide-exp {
  font-size: 22rpx;
  color: #888;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.guide-specialty { font-size: 24rpx; color: #C62828; display: block; margin-bottom: 6rpx; }
.guide-intro     { font-size: 24rpx; color: #666; display: block; line-height: 1.6; margin-bottom: 12rpx; }

.guide-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.guide-rating-wrap { display: flex; align-items: center; gap: 4rpx; }
.star-sm   { font-size: 24rpx; }
.rating-val { font-size: 28rpx; font-weight: bold; color: #FF9800; }
.rating-cnt { font-size: 22rpx; color: #bbb; }
.guide-price { font-size: 28rpx; font-weight: bold; color: #C62828; }

.guide-book-btn {
  background: linear-gradient(90deg, #C62828, #E53935);
  color: #fff;
  padding: 20rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: bold;
  text-align: center;
  flex-shrink: 0;
  align-self: center;
  min-width: 88rpx;
}

.guide-book-btn:active { opacity: 0.85; }
.btn-disabled { background: #ccc; }

/* ===== Comment Wall ===== */
.publish-comment-btn {
  background: linear-gradient(90deg, #C62828, #E53935);
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.publish-comment-btn:active { opacity: 0.85; }

.comment-input-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
}

.comment-textarea {
  width: 100%;
  height: 180rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
  display: block;
}

.comment-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  align-items: center;
}

.comment-cancel { font-size: 28rpx; color: #999; }

.comment-submit {
  background: #C62828;
  color: #fff;
  padding: 14rpx 36rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C62828, #E53935);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-letter { font-size: 30rpx; color: #fff; font-weight: bold; }

.comment-content { flex: 1; min-width: 0; }

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.comment-author { font-size: 28rpx; font-weight: bold; color: #333; }
.comment-date   { font-size: 22rpx; color: #bbb; }

.comment-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  display: block;
  margin-bottom: 12rpx;
}

.comment-like {
  display: inline-block;
  font-size: 24rpx;
  color: #888;
  padding: 6rpx 16rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.comment-like:active { background: #FFEBEE; color: #C62828; }

/* ===== Elder Mode ===== */
.elder-mode .section-title  { font-size: 44rpx; }
.elder-mode .article-title  { font-size: 34rpx; }
.elder-mode .article-summary { font-size: 30rpx; }
.elder-mode .site-name      { font-size: 38rpx; }
.elder-mode .site-desc      { font-size: 32rpx; }
.elder-mode .guide-name     { font-size: 36rpx; }
.elder-mode .guide-intro    { font-size: 30rpx; }
.elder-mode .comment-text   { font-size: 34rpx; }
.elder-mode .nav-text       { font-size: 30rpx; }

/* ===== Read Aloud Button ===== */
.read-aloud-btn {
  position: fixed;
  right: 30rpx;
  bottom: 160rpx;
  background: linear-gradient(135deg, #C62828, #E53935);
  color: #fff;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(198, 40, 40, 0.4);
  z-index: 999;
  gap: 4rpx;
}

.read-aloud-btn:active { opacity: 0.85; transform: scale(0.95); }

.read-icon  { font-size: 36rpx; }
.read-label { font-size: 20rpx; }
