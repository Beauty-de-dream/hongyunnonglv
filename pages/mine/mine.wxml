<!--pages/mine/mine.wxml - 个人中心-->
<view class="page-mine {{elderMode ? 'elder-mode' : ''}}">

  <!-- 朗读按钮（悬浮） -->
  <view class="read-aloud-btn" bindtap="onReadAloud" wx:if="{{elderMode}}">
    <text class="read-icon">🔊</text>
    <text class="read-label">朗读</text>
  </view>

  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-info" bindtap="onLogin" wx:if="{{!userInfo}}">
      <view class="avatar-default">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="user-text">
        <text class="user-name">点击登录</text>
        <text class="user-tip">登录后享受更多服务</text>
      </view>
    </view>
    <view class="user-info" wx:else>
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-text">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-tip">欢迎使用滴滴打农</text>
      </view>
    </view>
  </view>

  <!-- 我的订单 -->
  <view class="section-card">
    <view class="card-header">
      <text class="card-header-title">我的订单</text>
      <text class="card-header-more" bindtap="goToOrders" data-tab="all">查看全部 ></text>
    </view>
    <view class="order-grid">
      <view class="order-item" bindtap="goToOrders" data-tab="machinery">
        <view class="order-icon-wrap">
          <text class="order-icon">🚜</text>
          <text class="order-badge" wx:if="{{orderCounts.machinery > 0}}">{{orderCounts.machinery}}</text>
        </view>
        <text class="order-label">农机订单</text>
      </view>
      <view class="order-item" bindtap="goToOrders" data-tab="jobs">
        <view class="order-icon-wrap">
          <text class="order-icon">💼</text>
          <text class="order-badge" wx:if="{{orderCounts.jobs > 0}}">{{orderCounts.jobs}}</text>
        </view>
        <text class="order-label">务工申请</text>
      </view>
      <view class="order-item" bindtap="goToOrders" data-tab="picking">
        <view class="order-icon-wrap">
          <text class="order-icon">🍎</text>
          <text class="order-badge" wx:if="{{orderCounts.picking > 0}}">{{orderCounts.picking}}</text>
        </view>
        <text class="order-label">采摘/民宿</text>
      </view>
      <view class="order-item" bindtap="goToOrders" data-tab="all">
        <view class="order-icon-wrap">
          <text class="order-icon">📋</text>
          <text class="order-badge" wx:if="{{orderCounts.all > 0}}">{{orderCounts.all}}</text>
        </view>
        <text class="order-label">全部订单</text>
      </view>
    </view>

    <!-- 最近订单预览 -->
    <view class="recent-orders" wx:if="{{recentOrders.length > 0}}">
      <view class="recent-divider"></view>
      <view class="recent-order-item" wx:for="{{recentOrders}}" wx:key="orderId" bindtap="goToOrders" data-tab="{{item.orderTab}}">
        <view class="recent-order-left">
          <text class="recent-type-icon" wx:if="{{item.displayType === 'machinery'}}">🚜</text>
          <text class="recent-type-icon" wx:if="{{item.displayType === 'jobs'}}">💼</text>
          <text class="recent-type-icon" wx:if="{{item.displayType === 'picking'}}">🍎</text>
          <text class="recent-type-icon" wx:if="{{item.displayType === 'minsu'}}">🏡</text>
          <view class="recent-order-info">
            <text class="recent-order-name">{{item.itemName}}</text>
            <text class="recent-order-time">{{item.createTime}}</text>
          </view>
        </view>
        <text class="recent-order-status {{item.status === 'pending' ? 'status-pending' : item.status === 'confirmed' ? 'status-confirmed' : item.status === 'completed' ? 'status-completed' : 'status-cancelled'}}">
          {{item.status === 'pending' ? '待确认' : item.status === 'confirmed' ? '已确认' : item.status === 'completed' ? '已完成' : '已取消'}}
        </text>
      </view>
    </view>
  </view>

  <!-- SOS 紧急求助按钮 -->
  <view class="sos-btn" bindtap="goToEmergency">
    <text class="sos-icon">🆘</text>
    <text class="sos-text">SOS 紧急求助</text>
  </view>

  <!-- 保险服务入口 -->
  <view class="section-card insurance-card" bindtap="goToInsurance">
    <view class="insurance-card-inner">
      <view class="insurance-card-left">
        <view class="insurance-icon-wrap">
          <text class="insurance-icon">🛡️</text>
        </view>
        <view class="insurance-text">
          <text class="insurance-title">我的保障</text>
          <text class="insurance-desc">意外险 · 设备险 · 全面保障</text>
        </view>
      </view>
      <text class="insurance-arrow">></text>
    </view>
    <view class="insurance-tags">
      <text class="insurance-tag">人身意外险</text>
      <text class="insurance-tag">设备损坏险</text>
      <text class="insurance-tag">劳务保障</text>
    </view>
  </view>

  <!-- 我要发布 -->
  <view class="section-card" wx:if="{{!elderMode}}">
    <view class="card-header">
      <text class="card-header-title">我要发布</text>
    </view>
    <view class="publish-grid">
      <view class="publish-item" bindtap="goToPublish" data-tab="machinery">
        <view class="publish-icon-wrap publish-icon-green">
          <text class="publish-icon">🚜</text>
        </view>
        <text class="publish-label">农机出租</text>
        <text class="publish-desc">发布闲置农机</text>
      </view>
      <view class="publish-item" bindtap="goToPublish" data-tab="jobs">
        <view class="publish-icon-wrap publish-icon-orange">
          <text class="publish-icon">💼</text>
        </view>
        <text class="publish-label">务工招聘</text>
        <text class="publish-desc">发布用工需求</text>
      </view>
      <view class="publish-item" bindtap="goToPublish" data-tab="picking">
        <view class="publish-icon-wrap publish-icon-blue">
          <text class="publish-icon">🍎</text>
        </view>
        <text class="publish-label">采摘发布</text>
        <text class="publish-desc">发布采摘园信息</text>
      </view>
    </view>
  </view>

  <!-- 常用功能 -->
  <view class="section-card">
    <view class="card-header">
      <text class="card-header-title">常用功能</text>
    </view>
    <view class="menu-list">
      <view class="menu-item hide-in-elder" bindtap="goToAbout">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item hide-in-elder" bindtap="goToPartnership">
        <view class="menu-left">
          <text class="menu-icon">🤝</text>
          <text class="menu-text">合作推广</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="onContact">
        <view class="menu-left">
          <text class="menu-icon">📞</text>
          <text class="menu-text">联系我们</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item hide-in-elder" bindtap="showComingSoon">
        <view class="menu-left">
          <text class="menu-icon">❤️</text>
          <text class="menu-text">我的收藏</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item hide-in-elder" bindtap="showComingSoon">
        <view class="menu-left">
          <text class="menu-icon">⭐</text>
          <text class="menu-text">我的评价</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item hide-in-elder" bindtap="showComingSoon">
        <view class="menu-left">
          <text class="menu-icon">🔔</text>
          <text class="menu-text">消息通知</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-left">
          <text class="menu-icon">⚙️</text>
          <text class="menu-text">设置</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 平台数据 -->
  <view class="section-card hide-in-elder">
    <view class="card-header">
      <text class="card-header-title">平台数据</text>
    </view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{stats.machineryCount}}+</text>
        <text class="stat-label">注册农机</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.workerCount}}+</text>
        <text class="stat-label">活跃务工</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.gardenCount}}+</text>
        <text class="stat-label">合作园区</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.satisfaction}}%</text>
        <text class="stat-label">满意度</text>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer hide-in-elder">
    <text class="footer-text">© 2024 滴滴打农平台</text>
    <text class="footer-text">连接希望的田野，让每一份耕耘都有价值</text>
    <text class="footer-version">版本 1.0.0</text>
  </view>

</view>
