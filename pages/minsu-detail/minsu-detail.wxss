/* pages/minsu-detail/minsu-detail.wxss */

.page-detail {
  padding-bottom: 160rpx;
  background: #f5f5f5;
}

.detail-image {
  width: 100%;
  height: 480rpx;
  display: block;
}

.detail-info {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.detail-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  line-height: 1.4;
  flex: 1;
  margin-right: 20rpx;
  word-wrap: break-word;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin: 16rpx 0;
}

.detail-price {
  font-size: 44rpx;
  font-weight: bold;
  color: #4CAF50;
}

.detail-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-top: 16rpx;
  white-space: normal;
}

.detail-card {
  background: #fff;
  margin: 0 0 20rpx;
  padding: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  flex: 1;
  white-space: normal;
  word-wrap: break-word;
}

.info-value.link {
  color: #1976D2;
}

/* 农事体验列表 */
.exp-list {
  display: flex;
  flex-direction: column;
}

.exp-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.exp-item:last-child {
  border-bottom: none;
}

.exp-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #E8F5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.exp-icon {
  font-size: 36rpx;
}

.exp-info {
  flex: 1;
}

.exp-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.exp-duration {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* 费用预览 */
.cost-preview {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.cost-label {
  font-size: 28rpx;
  color: #666;
}

.cost-value {
  font-size: 36rpx;
  color: #4CAF50;
  font-weight: bold;
}

/* 表单 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 84rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #4CAF50;
  background: #fff;
}

.form-picker {
  width: 100%;
  height: 84rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #333;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.bottom-btn-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #eee;
}

.bottom-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.bottom-label {
  font-size: 22rpx;
  color: #666;
}

.bottom-btn-right {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4CAF50;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: #4CAF50;
  color: #fff;
}

.btn-lg {
  height: 96rpx;
  font-size: 34rpx;
  border-radius: 48rpx;
}

/* flex工具 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 标签 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.tag-green {
  background: #C8E6C9;
  color: #2E7D32;
}

.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}

.badge-green {
  background: #4CAF50;
}
