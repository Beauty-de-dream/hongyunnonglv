/* pages/jobs-detail/jobs-detail.wxss */

.page-detail {
  padding-bottom: 160rpx;
}

.job-header {
  background: linear-gradient(135deg, #FFA726 0%, #FF9800 50%, #E65100 100%);
  padding: 50rpx 30rpx;
  display: flex;
  flex-direction: column;
}

.job-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  display: block;
  white-space: normal;
  word-wrap: break-word;
  line-height: 1.4;
}

.job-salary {
  font-size: 36rpx;
  color: #FFD54F;
  font-weight: bold;
}

.detail-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: var(--radius-md);
  padding: 30rpx;
  box-shadow: var(--shadow-md);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  white-space: normal;
}

.job-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 24rpx;
  white-space: normal;
  word-wrap: break-word;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.salary {
  color: #4CAF50;
  font-weight: bold;
}

.info-value.link {
  color: #1976D2;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

/* 纠纷调解入口 */
.dispute-banner {
  margin: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border: 2rpx solid #FFD54F;
  border-radius: var(--radius-md);
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dispute-banner-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.dispute-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.dispute-text {
  display: flex;
  flex-direction: column;
}

.dispute-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #E65100;
  margin-bottom: 4rpx;
}

.dispute-desc {
  font-size: 22rpx;
  color: #F57C00;
}

.dispute-arrow {
  font-size: 28rpx;
  color: #FF9800;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bottom-btn-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
}

.bottom-icon {
  font-size: 36rpx;
}

.bottom-label {
  font-size: 22rpx;
  color: #666;
}

.bottom-btn-right {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  margin-left: 20rpx;
}

.bottom-btn-right.warning {
  background: #FF9800;
}
