/* pages/contract/contract.wxss */

.page-contract {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 180rpx;
}

/* 顶部横幅 */
.contract-hero {
  background: linear-gradient(135deg, #1565C0 0%, #0D47A1 100%);
  padding: 50rpx 30rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.hero-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.hero-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

/* 卡片 */
.section-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.required-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #FFEBEE;
  color: #D32F2F;
  border-radius: 10rpx;
  margin-left: 12rpx;
}

.optional-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #E3F2FD;
  color: #1565C0;
  border-radius: 10rpx;
  margin-left: 12rpx;
}

/* 合约基本信息 */
.contract-info {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.highlight {
  color: #4CAF50;
  font-weight: bold;
}

/* 合约条款 */
.terms-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.terms-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

/* 保险选择区域 */
.insurance-section {
  border: 2rpx solid #E3F2FD;
}

.insurance-info {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.insurance-plans {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plan-option {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.plan-option.plan-selected {
  border-color: #1565C0;
  background: #E8EAF6;
}

.plan-radio {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 4rpx;
  transition: all 0.2s ease;
  font-size: 24rpx;
  color: #fff;
}

.plan-radio.checked {
  background: #1565C0;
  border-color: #1565C0;
}

.plan-info {
  flex: 1;
}

.plan-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.plan-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.plan-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #1565C0;
}

.plan-recommend {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  background: #FF9800;
  color: #fff;
  border-radius: 8rpx;
}

.plan-detail {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

/* 费用预览 */
.cost-section {
  background: #F5F5F5;
}

.cost-rows {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cost-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.cost-row.total {
  border-top: 2rpx solid #ddd;
  padding-top: 16rpx;
  margin-top: 8rpx;
}

.cost-label {
  font-size: 26rpx;
  color: #666;
}

.cost-row.total .cost-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.cost-value {
  font-size: 28rpx;
  color: #333;
}

.cost-row.total .cost-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #D32F2F;
}

/* 双方确认 */
.confirm-section {
  border: 2rpx solid #C8E6C9;
}

.confirm-party {
  margin-bottom: 28rpx;
}

.confirm-party:last-child {
  margin-bottom: 0;
}

.party-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.party-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.party-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.checkbox-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 14rpx;
  transition: all 0.2s ease;
  font-size: 26rpx;
  color: #fff;
}

.checkbox.checked {
  background: #4CAF50;
  border-color: #4CAF50;
}

.checkbox-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  flex: 1;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 20rpx;
  z-index: 100;
}

.action-btn {
  height: 92rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.action-btn.cancel {
  width: 200rpx;
  background: #f5f5f5;
  color: #666;
}

.action-btn.confirm {
  flex: 1;
  background: #1565C0;
  color: #fff;
}

.action-btn.confirm.disabled {
  background: #B0BEC5;
  color: rgba(255, 255, 255, 0.7);
}
