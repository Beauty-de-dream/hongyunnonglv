/* pages/miao/miao.wxss */

.page-miao {
  background: #f5f5f5;
  padding-bottom: 0;
}

/* ===== Hero Banner ===== */
.hero-banner {
  height: 380rpx;
  background: linear-gradient(135deg, #4A148C 0%, #6A1B9A 45%, #9C27B0 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.hero-banner::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.hero-content {
  display: flex;
  flex-direction: column;
  z-index: 1;
}

.hero-badge {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  display: inline-block;
  width: fit-content;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  display: block;
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

/* ===== Quick Nav ===== */
.quick-nav {
  display: flex;
  background: #fff;
  padding: 28rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.nav-item:active { opacity: 0.7; }

.nav-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.nav-purple { background: #EDE7F6; }
.nav-pink   { background: #FCE4EC; }
.nav-teal   { background: #E0F2F1; }
.nav-green  { background: #E8F5E9; }

.nav-text { font-size: 24rpx; color: #555; }

/* ===== Sections ===== */
.section {
  padding: 40rpx 24rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.section-purple-light { background: #F3E5F5; }

.section-header { margin-bottom: 30rpx; }

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.title-bar { width: 6rpx; height: 40rpx; border-radius: 3rpx; }
.title-bar-purple { background: #6A1B9A; }

.section-title { font-size: 36rpx; font-weight: bold; color: #222; }
.section-subtitle { font-size: 26rpx; color: #999; padding-left: 18rpx; }

/* ===== Culture Cards ===== */
.culture-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.culture-card {
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
}

.culture-card:active { transform: scale(0.98); }

.culture-card-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  width: 100rpx;
}

.culture-icon { font-size: 52rpx; }

.culture-name {
  font-size: 26rpx;
  font-weight: bold;
  text-align: center;
  display: block;
}

.culture-card-right { flex: 1; min-width: 0; }

.culture-desc {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  display: block;
  margin-bottom: 14rpx;
}

.culture-features {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.ctag {
  font-size: 22rpx;
  padding: 5rpx 14rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid currentColor;
}

.culture-arrow {
  font-size: 28rpx;
  align-self: center;
  flex-shrink: 0;
}

/* ===== Festival Cards ===== */
.festival-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.festival-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(106, 27, 154, 0.08);
}

.festival-card:active { transform: scale(0.98); }

.festival-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.festival-icon { font-size: 52rpx; flex-shrink: 0; }

.festival-title-wrap { flex: 1; min-width: 0; }

.festival-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A148C;
  display: block;
  margin-bottom: 4rpx;
}

.festival-location { font-size: 24rpx; color: #888; display: block; }

.festival-countdown {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.countdown-upcoming { background: #E8F5E9; color: #2E7D32; }
.countdown-past     { background: #f5f5f5; color: #999; }

.festival-date  { font-size: 24rpx; color: #888; display: block; margin-bottom: 10rpx; }
.festival-desc  { font-size: 26rpx; color: #555; line-height: 1.6; display: block; margin-bottom: 14rpx; }

.festival-activities {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.activity-tag {
  font-size: 22rpx;
  background: #EDE7F6;
  color: #6A1B9A;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

/* ===== Arts ===== */
.arts-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.art-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  display: flex;
  flex-direction: row;
}

.art-card:active { transform: scale(0.98); }

.art-img-wrap {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  flex-shrink: 0;
}

.art-avatar { width: 100%; height: 100%; }

.art-play-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
}

.play-icon { font-size: 60rpx; color: #fff; }

.art-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.art-name { font-size: 30rpx; font-weight: bold; color: #4A148C; display: block; }

.art-artisan-row { display: flex; align-items: center; gap: 10rpx; }
.artisan-name  { font-size: 26rpx; font-weight: bold; color: #333; }

.artisan-level {
  font-size: 20rpx;
  color: #6A1B9A;
  background: #EDE7F6;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.artisan-age-text { font-size: 22rpx; color: #bbb; }
.art-desc { font-size: 24rpx; color: #666; line-height: 1.6; display: block; }

.art-play-btn {
  margin-top: auto;
  background: #EDE7F6;
  color: #6A1B9A;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: bold;
  text-align: center;
  display: block;
}

/* ===== CTA ===== */
.cta-section {
  background: linear-gradient(135deg, #4A148C, #9C27B0);
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.cta-title  { font-size: 40rpx; font-weight: bold; color: #fff; display: block; }
.cta-desc   { font-size: 28rpx; color: rgba(255, 255, 255, 0.85); display: block; text-align: center; }

.cta-btn {
  background: #fff;
  color: #6A1B9A;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.cta-btn:active { opacity: 0.85; }
