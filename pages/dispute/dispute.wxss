/* pages/dispute/dispute.wxss */

.page-dispute {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部横幅 */
.dispute-hero {
  background: linear-gradient(135deg, #FFA726 0%, #FF9800 50%, #E65100 100%);
  padding: 60rpx 30rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 卡片 */
.section-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 调解流程 */
.steps {
  display: flex;
  flex-direction: column;
  padding: 0 12rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FF9800;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.step-content {
  display: flex;
  flex-direction: column;
  padding-top: 4rpx;
}

.step-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.step-desc {
  font-size: 24rpx;
  color: #999;
}

.step-line {
  width: 4rpx;
  height: 30rpx;
  background: #FFD54F;
  margin-left: 26rpx;
  margin: 8rpx 0 8rpx 26rpx;
}

/* 表单 */
.form-area {
  display: flex;
  flex-direction: column;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 84rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #FF9800;
  background: #fff;
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-textarea.small {
  height: 160rpx;
}

.form-textarea:focus {
  border-color: #FF9800;
  background: #fff;
}

.form-picker {
  width: 100%;
  height: 84rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.placeholder {
  color: #999;
}

/* 提交按钮 */
.submit-btn {
  background: #FF9800;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
}

.submit-btn:active {
  background: #E65100;
}

/* 温馨提示 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 客服热线 */
.hotline-bar {
  margin: 30rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.hotline-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.hotline-text {
  font-size: 28rpx;
  color: #FF9800;
  font-weight: bold;
}
