/* pages/publish/publish.wxss */

.page-publish {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 标签栏 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 12rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
  transition: color 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-icon {
  font-size: 28rpx;
}

.tab-item.active {
  color: #4CAF50;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 6rpx;
  background: #4CAF50;
  border-radius: 3rpx;
}

/* 表单区域 */
.form-section {
  padding: 20rpx 24rpx;
}

.form-header {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  border-radius: 16rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
}

.form-header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.form-header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  line-height: 1.6;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 84rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.form-input:focus {
  border-color: #4CAF50;
  background: #fff;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.form-textarea:focus {
  border-color: #4CAF50;
  background: #fff;
}

.form-picker {
  width: 100%;
  height: 84rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.placeholder {
  color: #999;
}

/* 我的发布 */
.my-publish-section {
  margin-top: 30rpx;
}

.my-publish-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.my-publish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.my-publish-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.publish-item-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.publish-item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.publish-item-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: #E8F5E9;
  color: #2E7D32;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.publish-item-badge.badge-orange {
  background: #FFF3E0;
  color: #E65100;
}

.publish-item-badge.badge-blue {
  background: #E3F2FD;
  color: #1565C0;
}

.publish-item-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.publish-item-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-lg {
  height: 96rpx;
  font-size: 34rpx;
  border-radius: 48rpx;
  margin-top: 16rpx;
}

.btn-primary {
  background: #4CAF50;
  color: #fff;
}

.btn-warning {
  background: #FF9800;
  color: #fff;
}

.btn-info {
  background: #2196F3;
  color: #fff;
}

/* 设备损坏保险选项 */
.insurance-option {
  background: #F1F8E9;
  border: 2rpx solid #C5E1A5;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 30rpx;
}

.insurance-option-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.insurance-option-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.insurance-option-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #33691E;
}

.insurance-option-desc {
  font-size: 24rpx;
  color: #689F38;
  margin-bottom: 20rpx;
  display: block;
  line-height: 1.6;
}

.insurance-plans {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.insurance-plan {
  flex: 1;
  background: #fff;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}

.insurance-plan.plan-active {
  border-color: #4CAF50;
  background: #E8F5E9;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
}

.plan-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.plan-active .plan-name {
  color: #2E7D32;
}

.plan-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 6rpx;
}

.plan-detail {
  font-size: 20rpx;
  color: #999;
}

.plan-active .plan-detail {
  color: #558B2F;
}

.insurance-plan-none {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 12rpx 0;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.insurance-plan-none.plan-none-active {
  color: #F44336;
  font-weight: bold;
}
