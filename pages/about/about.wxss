/* pages/about/about.wxss */

.page-about {
  padding-bottom: 40rpx;
}

.page-header {
  background: linear-gradient(135deg, #42A5F5 0%, #1976D2 50%, #0D47A1 100%);
  padding: 50rpx 30rpx 70rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.page-header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
}

.section {
  padding: 40rpx 24rpx;
}

.section-gray {
  background: #f5f5f5;
}

.section-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.section-subtitle {
  font-size: 26rpx;
  color: #999;
}

.about-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 20rpx;
  white-space: normal;
  word-wrap: break-word;
}

/* 统计数据 */
.stats-grid {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  width: 23%;
}

.stat-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 时间线 */
.timeline {
  display: flex;
  flex-direction: column;
  padding-left: 30rpx;
  border-left: 4rpx solid #e0e0e0;
}

.timeline-item {
  position: relative;
  padding-left: 30rpx;
  margin-bottom: 40rpx;
}

.timeline-dot {
  position: absolute;
  left: -40rpx;
  top: 6rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
}

.timeline-content {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.timeline-year {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  white-space: normal;
  word-wrap: break-word;
}

/* 价值观 */
.value-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.value-item {
  width: 48%;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-md);
  transition: transform 0.2s ease;
}

.value-item:active {
  transform: translateY(-4rpx);
}

.value-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.value-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.value-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
  white-space: normal;
  line-height: 1.5;
}

/* 团队 */
.team-list {
  display: flex;
  overflow-x: auto;
  padding-bottom: 20rpx;
  -webkit-overflow-scrolling: touch;
}

.team-card {
  width: 420rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.team-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.team-avatar-text {
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
}

.team-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.team-role {
  font-size: 24rpx;
  color: #1976D2;
  margin-bottom: 12rpx;
}

.team-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  white-space: normal;
  word-wrap: break-word;
  line-height: 1.6;
}

/* 联系方式 */
.contact-list {
  display: flex;
  flex-direction: column;
}

.contact-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #fff;
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.contact-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.contact-content {
  display: flex;
  flex-direction: column;
}

.contact-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #bbb;
}
