/* pages/insurance/insurance.wxss */

.page-insurance {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部横幅 */
.insurance-hero {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 50%, #1B5E20 100%);
  padding: 60rpx 30rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 卡片 */
.section-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header-bar {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.card-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  background: #E8F5E9;
  color: #2E7D32;
}

.card-tag.tag-blue {
  background: #E3F2FD;
  color: #1565C0;
}

.card-main-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-body {
  padding: 24rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}

/* 方案列表 */
.plan-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plan-card {
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 24rpx;
  transition: all 0.2s ease;
  position: relative;
}

.plan-card.selected {
  border-color: #4CAF50;
  background: #F1F8E9;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.15);
}

.plan-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  color: #666;
  display: inline-block;
  margin-bottom: 12rpx;
}

.plan-tag.tag-hot {
  background: #FFF3E0;
  color: #E65100;
}

.plan-tag.tag-premium {
  background: #F3E5F5;
  color: #7B1FA2;
}

.plan-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
  display: block;
  margin-bottom: 16rpx;
}

.plan-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.plan-detail-item {
  font-size: 24rpx;
  color: #666;
  padding-left: 20rpx;
  position: relative;
}

.plan-detail-item::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: #4CAF50;
  font-size: 22rpx;
}

/* 我的保单 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

.policy-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.policy-item:last-child {
  border-bottom: none;
}

.policy-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.policy-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.policy-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.status-active {
  background: #E8F5E9;
  color: #2E7D32;
}

.status-expired {
  background: #f5f5f5;
  color: #999;
}

.policy-plan {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
}

.policy-date {
  font-size: 22rpx;
  color: #bbb;
}

/* FAQ */
.faq-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.faq-q-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.faq-arrow {
  font-size: 24rpx;
  color: #ccc;
  transition: transform 0.2s;
}

.faq-arrow.open {
  transform: rotate(180deg);
}

.faq-answer {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding-left: 8rpx;
}

/* 客服 */
.service-bar {
  margin: 30rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.service-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.service-btn {
  background: #fff;
  border: 2rpx solid #4CAF50;
  color: #4CAF50;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
}
