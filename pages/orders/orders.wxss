/* pages/orders/orders.wxss */

.page-orders {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 标签栏 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: color 0.3s;
}

.tab-item.active {
  color: #4CAF50;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 6rpx;
  background: #4CAF50;
  border-radius: 3rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx 24rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-type-wrap {
  display: flex;
  align-items: center;
}

.order-type-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.order-type-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: #FFF3E0;
  color: #E65100;
}

.status-confirmed {
  background: #E8F5E9;
  color: #2E7D32;
}

.status-completed {
  background: #E3F2FD;
  color: #1565C0;
}

.status-cancelled {
  background: #f5f5f5;
  color: #999;
}

/* 订单内容 */
.order-body {
  padding: 24rpx;
}

.order-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
  white-space: normal;
  word-wrap: break-word;
  line-height: 1.4;
}

.order-info {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.order-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.price-text {
  color: #4CAF50;
  font-weight: bold;
  font-size: 28rpx;
}

.order-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-id {
  font-size: 22rpx;
  color: #bbb;
}

.order-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 订单底部操作 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-contact {
  font-size: 26rpx;
  color: #1976D2;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.action-cancel {
  border: 1rpx solid #999;
  color: #999;
}

.action-complete {
  background: #4CAF50;
  color: #fff;
}

.action-rate {
  background: #FF9800;
  color: #fff;
}

/* 已评价显示 */
.order-rating-display {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFF8E1;
  border-top: 1rpx solid #f5f5f5;
}

.rating-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.rating-stars-show {
  display: flex;
  align-items: center;
}

.star-icon-show {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.rating-score {
  font-size: 24rpx;
  color: #FF9800;
  margin-left: 12rpx;
  font-weight: bold;
}

/* 评价弹窗 */
.rating-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.rating-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rating-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.rating-modal-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.rating-stars {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.rating-star-item {
  padding: 10rpx;
}

.rating-star {
  font-size: 60rpx;
  transition: transform 0.2s;
}

.star-active {
  transform: scale(1.1);
}

.star-inactive {
  color: #ddd;
}

.rating-score-text {
  font-size: 28rpx;
  color: #FF9800;
  margin-bottom: 40rpx;
  min-height: 40rpx;
}

.rating-modal-btns {
  display: flex;
  width: 100%;
  gap: 24rpx;
}

.rating-btn-cancel {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #ddd;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #999;
}

.rating-btn-confirm {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FF9800;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-icon-text {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}
