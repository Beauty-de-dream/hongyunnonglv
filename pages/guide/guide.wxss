/* pages/guide/guide.wxss */

.page-guide {
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

.page-header {
  background: linear-gradient(135deg, #0D47A1, #1976D2);
  padding: 50rpx 30rpx 70rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  display: block;
}

.page-header-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
}

/* Features */
.features-section {
  background: #fff;
  margin: -30rpx 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  position: relative;
  z-index: 5;
}

.feature-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.feature-row:last-child { margin-bottom: 0; }

.feature-item {
  flex: 1;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 12rpx;
}

.fi-icon { font-size: 36rpx; flex-shrink: 0; }
.fi-title { font-size: 26rpx; font-weight: bold; color: #222; display: block; margin-bottom: 4rpx; }
.fi-desc  { font-size: 22rpx; color: #888; display: block; white-space: normal; }

/* Section */
.section {
  background: #fff;
  margin: 0 0 16rpx;
  padding: 30rpx 24rpx;
}

.section-header { margin-bottom: 24rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: #222; display: block; margin-bottom: 6rpx; }
.section-sub   { font-size: 26rpx; color: #999; display: block; }

/* Guide Cards */
.guide-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-card {
  background: #f8f9fb;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  box-shadow: 0 2rpx 8rpx rgba(21,101,192,0.08);
}

.guide-card:active { transform: scale(0.98); }

.guide-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 4rpx solid #E3F2FD;
}

.guide-info { flex: 1; min-width: 0; }

.guide-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.guide-name { font-size: 30rpx; font-weight: bold; color: #222; }

.guide-avail {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  color: #fff;
}

.avail-yes { background: #4CAF50; }
.avail-no  { background: #999; }

.guide-specialty { font-size: 24rpx; color: #1565C0; display: block; margin-bottom: 8rpx; }

.guide-intro-text {
  font-size: 24rpx;
  color: #666;
  display: block;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.guide-tag-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }

.gtag {
  font-size: 22rpx;
  background: #E3F2FD;
  color: #1565C0;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

.guide-meta-row { margin-bottom: 16rpx; }
.guide-meta { font-size: 24rpx; color: #888; }

.guide-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.guide-price { font-size: 30rpx; font-weight: bold; color: #1565C0; }

.book-btn {
  background: #1565C0;
  color: #fff;
  padding: 14rpx 28rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.book-btn:active { opacity: 0.85; }
.btn-disabled { background: #ccc; }

/* Tips */
.tips-section {
  background: #fff;
  margin: 0 0 16rpx;
  padding: 30rpx 24rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
  display: block;
  margin-bottom: 20rpx;
}

.tip-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tip-num {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  background: #1565C0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  flex: 1;
  display: block;
  padding-top: 8rpx;
}
