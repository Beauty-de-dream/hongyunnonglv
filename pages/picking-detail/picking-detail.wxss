/* pages/picking-detail/picking-detail.wxss */

.page-detail {
  padding-bottom: 160rpx;
}

.detail-image {
  width: 100%;
  height: 480rpx;
}

.detail-info {
  padding: 30rpx;
  background: #fff;
}

.detail-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1976D2;
  display: block;
  margin-bottom: 12rpx;
  white-space: normal;
  word-wrap: break-word;
  line-height: 1.4;
}

.price-row {
  margin-bottom: 16rpx;
}

.detail-price {
  font-size: 42rpx;
  font-weight: bold;
  color: #4CAF50;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  white-space: normal;
  word-wrap: break-word;
}

.detail-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: var(--radius-md);
  padding: 30rpx;
  box-shadow: var(--shadow-md);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  white-space: normal;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  max-width: 380rpx;
}

.info-value.link {
  color: #1976D2;
}

.cost-preview {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.cost-label {
  font-size: 28rpx;
  color: #666;
}

.cost-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-left: 12rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bottom-btn-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
}

.bottom-icon {
  font-size: 36rpx;
}

.bottom-label {
  font-size: 22rpx;
  color: #666;
}

.bottom-btn-right {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  margin-left: 20rpx;
}

.bottom-btn-right.info {
  background: #2196F3;
}
